# Frontend environment — copy to .env.local and adjust as needed.

# Backend origin for PRODUCTION builds (e.g. https://api.example.com).
# Leave empty in development: the Vite dev server (port 2200) proxies /api to the
# backend (port 3300). API types are generated from the backend spec: `npm run gen:api`.
VITE_API_URL=

# LINE LIFF app id (from the LINE Developers console). Leave empty for a plain
# dev browser — the app falls back to a generic "Hello, World" greeting.
VITE_LIFF_ID=
