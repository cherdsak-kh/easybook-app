{
  "name": "easybook-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:api": "openapi-typescript http://localhost:3300/docs-json -o src/lib/api-types.ts",
    "prepare": "node -e \"try{require('child_process').execSync('husky',{stdio:'inherit'})}catch(e){}\""
  },
  "lint-staged": {
    "*.{ts,tsx}": "oxlint"
  },
  "dependencies": {
    "@heroicons/react": "^2.1.5",
    "@line/liff": "^2.29.1",
    "chart.js": "^4.4.0",
    "openapi-fetch": "^0.13.0",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.2.7",
    "react-easy-crop": "^6.2.2",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "daisyui": "^5.6.18",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "openapi-typescript": "^7.4.0",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
